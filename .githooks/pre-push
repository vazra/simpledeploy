#!/usr/bin/env bash
# Lightweight pre-push checks. Bypass with `git push --no-verify`.
set -e

if [ -n "$SIMPLEDEPLOY_SKIP_HOOKS" ]; then
  exit 0
fi

echo "[pre-push] go vet"
go vet ./...

# golangci-lint mirrors CI's check. Use the repo's .golangci.yml.
# Skippable via SIMPLEDEPLOY_SKIP_LINT=1 when iterating fast.
if [ -z "$SIMPLEDEPLOY_SKIP_LINT" ]; then
  if ! command -v golangci-lint >/dev/null 2>&1; then
    echo "[pre-push] golangci-lint not installed. Install: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.4"
    echo "[pre-push] (bypass with SIMPLEDEPLOY_SKIP_LINT=1 or --no-verify)"
    exit 1
  fi
  echo "[pre-push] golangci-lint"
  golangci-lint run ./...
fi

echo "[pre-push] go build"
go build ./...

echo "[pre-push] go test -short"
go test -short ./...

if [ -d ui/node_modules ]; then
  echo "[pre-push] ui vitest"
  (cd ui && npm test --silent)
  # UI build doubles as a lint/type check: the Svelte + Vite compiler
  # fails on undefined exports, missing imports, and a11y violations.
  # Catches regressions like a missing named export before CI.
  echo "[pre-push] ui build"
  (cd ui && npm run build --silent >/dev/null)
else
  echo "[pre-push] ui checks skipped (run 'cd ui && npm install' to enable)"
fi

echo "[pre-push] ok"
