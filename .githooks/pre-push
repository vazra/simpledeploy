#!/usr/bin/env bash
# Lightweight pre-push checks. Bypass with `git push --no-verify`.
set -e

if [ -n "$SIMPLEDEPLOY_SKIP_HOOKS" ]; then
  exit 0
fi

echo "[pre-push] go vet"
go vet ./...

echo "[pre-push] go build"
go build ./...

echo "[pre-push] go test -short"
go test -short ./...

if [ -d ui/node_modules ]; then
  echo "[pre-push] ui vitest"
  (cd ui && npm test --silent)
else
  echo "[pre-push] ui vitest skipped (run 'cd ui && npm install' to enable)"
fi

echo "[pre-push] ok"
